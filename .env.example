# Quickstart environment. Do not commit this file.
# Source it before Helm commands: set -a; source .env; set +a
EVALHUB_BASE_URL='http://gaussia-evalhub-evalhub.gaussia-evalhub-quickstart.svc.cluster.local'
EVALHUB_AUTH_TOKEN=''
EVALHUB_TENANT='gaussia-evalhub-quickstart'
EVALHUB_INSECURE='true'
EVALHUB_EXPERIMENT_NAME='alquimia-gaussia'
MLFLOW_TRACKING_URI='https://mlflow.redhat-ods-applications.svc.cluster.local:8443'
MLFLOW_TRACKING_TOKEN=''
MLFLOW_WORKSPACE='redhat-ods-applications'
GAUSSIA_JUDGE_MODEL='openai/deepseek-r1-distill-qwen-14b'
GAUSSIA_JUDGE_BASE_URL='https://litellm-prod.apps.maas.redhatworkshops.io/v1'
GAUSSIA_JUDGE_API_KEY='<token>'  # stored in OpenShift Secret by Helm (or use platform.provider.existingSecret)
GAUSSIA_JUDGE_TEMPERATURE='0.0'
GAUSSIA_JUDGE_USE_STRUCTURED_OUTPUT='false'
GAUSSIA_JUDGE_BOS_JSON_CLAUSE='```json'
GAUSSIA_JUDGE_EOS_JSON_CLAUSE='```'
GAUSSIA_AGENTIC_K='3'
GAUSSIA_AGENTIC_THRESHOLD='0.7'
GAUSSIA_AGENTIC_TOOL_THRESHOLD='1.0'
GAUSSIA_GUARDIAN_MODEL='openai/deepseek-r1-distill-qwen-14b'
GAUSSIA_GUARDIAN_BASE_URL='https://litellm-prod.apps.maas.redhatworkshops.io/v1'
GAUSSIA_GUARDIAN_API_KEY='<token>'  # stored in OpenShift Secret by Helm (or use platform.provider.existingSecret)
GAUSSIA_GUARDIAN_TEMPERATURE='0.01'
GAUSSIA_GUARDIAN_LOGPROBS='false'
GAUSSIA_GUARDIAN_TOKENIZER_MODEL="ibm-granite/granite-guardian-3.1-2b"
GAUSSIA_GUARDIAN_CHAT_COMPLETIONS="true"
GAUSSIA_TOXICITY_EMBEDDING_MODEL='all-MiniLM-L6-v2'
GAUSSIA_TOXICITY_STATISTICAL_MODE='frequentist'
GAUSSIA_JUDGE_MODEL_PROVIDER='openai'
GAUSSIA_PROVIDER_PACKAGE_SPEC="gaussia[evalhub]==1.1.0b2 langchain-openai"
