# Copy this file to .env and fill the values for your environment.
# .env is intentionally ignored by git.

# EvalHub
EVALHUB_BASE_URL="https://evalhub.example.com"
EVALHUB_AUTH_TOKEN="<evalhub-token>"
EVALHUB_TENANT="default"
EVALHUB_INSECURE="true"
EVALHUB_EXPERIMENT_NAME="gaussia-agent-evaluation"

# MLflow
MLFLOW_TRACKING_URI="https://mlflow.example.com"
MLFLOW_TRACKING_TOKEN="<mlflow-token>"
MLFLOW_WORKSPACE="<mlflow-workspace>"

# Evaluated agent or model shown in EvalHub and MLflow.
# Leave these blank to use the model metadata from each fixture.
GAUSSIA_EVALUATED_MODEL_NAME=""
GAUSSIA_EVALUATED_MODEL_URL=""

# Judge model used by context, conversational, and agentic benchmarks.
GAUSSIA_JUDGE_MODEL="<judge-model-name>"
GAUSSIA_JUDGE_MODEL_PROVIDER="openai"
GAUSSIA_JUDGE_BASE_URL="<judge-api-base-url>"
GAUSSIA_JUDGE_API_KEY="<judge-api-key>"
GAUSSIA_JUDGE_TEMPERATURE="0.0"
GAUSSIA_JUDGE_USE_STRUCTURED_OUTPUT="true"
GAUSSIA_JUDGE_BOS_JSON_CLAUSE='```json'
GAUSSIA_JUDGE_EOS_JSON_CLAUSE='```'

# Agentic benchmark thresholds.
GAUSSIA_AGENTIC_K="3"
GAUSSIA_AGENTIC_THRESHOLD="0.7"
GAUSSIA_AGENTIC_TOOL_THRESHOLD="1.0"

# Guardian model used by the bias benchmark.
GAUSSIA_GUARDIAN_MODEL="<guardian-model-name>"
GAUSSIA_GUARDIAN_TOKENIZER_MODEL="<guardian-tokenizer-model-name>"
GAUSSIA_GUARDIAN_BASE_URL="<guardian-api-base-url>"
GAUSSIA_GUARDIAN_API_KEY="<guardian-api-key>"
GAUSSIA_GUARDIAN_TEMPERATURE="0.01"
GAUSSIA_GUARDIAN_LOGPROBS="false"
GAUSSIA_GUARDIAN_CHAT_COMPLETIONS="false"

# Toxicity benchmark.
GAUSSIA_TOXICITY_EMBEDDING_MODEL="all-MiniLM-L6-v2"
GAUSSIA_TOXICITY_STATISTICAL_MODE="frequentist"
